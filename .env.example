# UnraidClaw CLI configuration
# Copy this file to .env and fill in your values
# cp .env.example .env

# Your Unraid server URL (IP or hostname)
UNRAIDCLAW_URL=https://tower.local:9876

# API key from the UnraidClaw Unraid plugin
UNRAIDCLAW_KEY=

# Set to 1 if using a self-signed TLS certificate
UNRAIDCLAW_TLS_SKIP=1
